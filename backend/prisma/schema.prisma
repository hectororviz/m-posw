generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ModuleKey {
  POS
  VENTAS
  SOCIOS
  TESORERIA
  ACREEDORES
  PRODUCTOS
  INTERNET
  REPORTES
  CONFIGURACION
  PLAYERS
}

enum ModuleAccess {
  HIDDEN
  READ
  FULL
}

enum SaleStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MP_QR
  TRANSFER
  FIADO
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum MovementType {
  ENTRADA
  SALIDA
}

enum AccountingMovementType {
  INCOME
  EXPENSE
}

enum ProductType {
  SIMPLE
  RAW_MATERIAL
  COMPOSITE
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique
  email     String?
  password  String
  role      Role     @default(USER)
  active    Boolean  @default(true)
  homeModule String?
  externalPosId   String?
  externalStoreId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
  cashClosures CashClose[]
  cashMovements CashMovement[]
  sessions  Session[]
  manualMovements ManualMovement[]
  journalEntries JournalEntry[]
  modulePermissions UserModulePermission[]
}

model CashClose {
  id                String   @id @default(uuid()) @db.Uuid
  from              DateTime
  to                DateTime
  closedAt          DateTime @default(now())
  closedByUserId    String   @db.Uuid
  note              String?
  salesCashTotal    Decimal  @default(0) @db.Decimal(10, 2)
  salesQrTotal      Decimal  @default(0) @db.Decimal(10, 2)
  salesTransferTotal Decimal @default(0) @db.Decimal(10, 2)
  salesTotal        Decimal  @default(0) @db.Decimal(10, 2)
  salesCount        Int      @default(0)
  movementsOutTotal Decimal  @default(0) @db.Decimal(10, 2)
  movementsInTotal  Decimal  @default(0) @db.Decimal(10, 2)
  movementsNet      Decimal  @default(0) @db.Decimal(10, 2)
  netCashDelta      Decimal  @default(0) @db.Decimal(10, 2)
  movementsCount    Int      @default(0)
  createdAt         DateTime @default(now())
  closedBy          User     @relation(fields: [closedByUserId], references: [id])

  @@index([to])
  @@index([closedAt])
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  iconName  String
  colorHex  String
  imagePath String?
  imageUpdatedAt DateTime?
  active    Boolean  @default(true)
  ticket    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
  socioBeneficios SocioBeneficio[]
}

model Product {
  id               String                @id @default(uuid()) @db.Uuid
  name             String
  price            Decimal               @db.Decimal(10, 2)
  stock            Decimal               @default(0) @db.Decimal(10, 4)
  type             ProductType           @default(SIMPLE)
  iconName         String?
  colorHex         String?
  imagePath        String?
  imageUpdatedAt   DateTime?
  active           Boolean               @default(true)
  categoryId       String                @db.Uuid
  category         Category              @relation(fields: [categoryId], references: [id])
  saleItems        SaleItem[]
  orderCounter     ProductOrderCounter?
  // Relaciones para recetas
  recipeAsComposite RecipeIngredient[]   @relation("CompositeProduct")
  recipeAsRawMaterial RecipeIngredient[] @relation("RawMaterialProduct")
  socioBeneficios   SocioBeneficio[]
  internetPlan      InternetPlan?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}


model ManualMovement {
  id        String       @id @default(uuid()) @db.Uuid
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  type      MovementType
  amount    Decimal      @db.Decimal(10, 2)
  reason    String
  userId    String       @db.Uuid
  user      User         @relation(fields: [userId], references: [id])
  manualMovementCategory ManualMovementCategory?

  @@index([createdAt])
}

model Sale {
  id        String     @id @default(uuid()) @db.Uuid
  orderNumber Int      @default(autoincrement())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  total     Decimal    @db.Decimal(10, 2)
  status    SaleStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod
  statusUpdatedAt DateTime @default(now())
  paymentStartedAt DateTime?
  paidAt    DateTime?
  ticketPrintedAt DateTime?
  cancelledAt DateTime?
  expiredAt DateTime?
  cashReceived Decimal? @db.Decimal(10, 2)
  changeAmount Decimal? @db.Decimal(10, 2)
  mpExternalReference String?
  mpOrderId String?
  mpPaymentId String?
  mpMerchantOrderId String?
  mpQrData String?
  mpStatus String?
  mpStatusDetail String?
  mpRaw Json?
  userId    String     @db.Uuid
  user      User       @relation(fields: [userId], references: [id])
  items     SaleItem[]
  mercadoPagoPayments MercadoPagoPayment[]
  movimientosMP MovimientoMP[]
  fiadoVenta       FiadoVenta?
  journalEntryId   String?        @unique @db.Uuid
  journalEntry     JournalEntry?  @relation("JournalEntrySale", fields: [journalEntryId], references: [id])
  vouchers         SaleVoucher[]
}

model SaleItem {
  id        String   @id @default(uuid()) @db.Uuid
  orderNumber Int    @default(autoincrement())
  saleId    String   @db.Uuid
  productId String   @db.Uuid
  quantity  Int
  subtotal  Decimal  @db.Decimal(10, 2)
  sale      Sale     @relation(fields: [saleId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId, revokedAt])
}

model MercadoPagoPayment {
  id        String   @id @default(uuid()) @db.Uuid
  saleId    String   @db.Uuid
  paymentId String?
  status    String
  approvedAt DateTime?
  payload   Json?
  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model PaymentEvent {
  id        String   @id @default(uuid()) @db.Uuid
  provider  String
  topic     String
  resourceId String
  createdAt DateTime @default(now())

  @@unique([provider, topic, resourceId])
}

model Setting {
  id          String   @id @default(uuid()) @db.Uuid
  storeName   String
  clubName    String   @default("")
  enableTicketPrinting Boolean @default(false)
  logoUrl     String?
  faviconUrl  String?
  okAnimationUrl String?
  errorAnimationUrl String?
  accentColor String?
  enableCashPayment Boolean @default(true)
  enableQrPayment Boolean @default(true)
  enableTransferPayment Boolean @default(true)
  enableFiadoPayment Boolean @default(false)
  enableSociosModule Boolean @default(true)
  enableTreasuryModule Boolean @default(true)
  enableAcreedoresModule Boolean @default(true)
  enableInternetModule        Boolean @default(false)
  enableAutoJournalPos        Boolean @default(true)
  enableAutoJournalAcreedores Boolean @default(true)
  enableAutoJournalSocios     Boolean @default(true)
  enableLigasModule           Boolean @default(false)
  enablePlayersModule         Boolean @default(false)
  movementInReasons String[] @default([])
  movementOutReasons String[] @default([])
  mpAccessToken   String?
  mpRefreshToken  String?
  mpTokenExpiresAt DateTime?
  mpCollectorId   String?
  mpStoreId       String?
  mpPosId         String?
  mpPosName       String?
  mpStoreName     String?
  mpExternalPosId   String?
  mpExternalStoreId String?
  mpQrData        String?
  mpLinked        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LigasConfig {
  id        String   @id @default(uuid()) @db.Uuid
  leagueId  String
  leagueName String
  teamId    String
  teamName  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductOrderCounter {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String   @unique @db.Uuid
  lastOrderNumber Int    @default(0)
  product       Product  @relation(fields: [productId], references: [id])
  updatedAt     DateTime @updatedAt
}

model CashMovement {
  id        String           @id @default(uuid()) @db.Uuid
  type      CashMovementType
  amount    Decimal          @default(0) @db.Decimal(10, 2)
  reason    String?
  isVoided  Boolean          @default(false)
  createdAt DateTime         @default(now())
  createdByUserId String     @db.Uuid
  createdBy User             @relation(fields: [createdByUserId], references: [id])

  @@index([createdAt])
}

enum CashMovementType {
  INCOME
  EXPENSE
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
}

model MovimientoMP {
  id            String   @id @default(uuid()) @db.Uuid
  saleId        String?  @db.Uuid
  sale          Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  paymentId     String   @unique
  monto         Decimal  @db.Decimal(10, 2)
  montoEsperado Decimal  @db.Decimal(10, 2)
  pagador       String?
  tipo          String?
  fecha         DateTime
  notificado    Boolean  @default(false)
  procesado     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([saleId])
  @@index([paymentId])
  @@index([notificado])
  @@index([createdAt])
}

model RecipeIngredient {
  id            String   @id @default(uuid()) @db.Uuid
  compositeId   String   @db.Uuid
  composite     Product  @relation("CompositeProduct", fields: [compositeId], references: [id], onDelete: Cascade)
  rawMaterialId String   @db.Uuid
  rawMaterial   Product  @relation("RawMaterialProduct", fields: [rawMaterialId], references: [id], onDelete: Cascade)
  quantity      Decimal  @db.Decimal(10, 4)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([compositeId, rawMaterialId])
  @@index([compositeId])
  @@index([rawMaterialId])
}

model AccountingCategory {
  id        String                   @id @default(uuid()) @db.Uuid
  name      String
  type      AccountingMovementType
  active    Boolean                  @default(true)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  movements AccountingMovement[]
  manualMovementCategories ManualMovementCategory[]
}

model AccountingMovement {
  id               String                   @id @default(uuid()) @db.Uuid
  type             AccountingMovementType
  amount           Decimal                  @db.Decimal(10, 2)
  description      String
  date             DateTime
  categoryId       String                   @db.Uuid
  category         AccountingCategory       @relation(fields: [categoryId], references: [id])
  refMovementId    String?                  @db.Uuid
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([date])
  @@index([categoryId])
  @@index([type])
}

model ManualMovementCategory {
  id                String             @id @default(uuid()) @db.Uuid
  manualMovementId  String             @unique @db.Uuid
  manualMovement    ManualMovement     @relation(fields: [manualMovementId], references: [id])
  categoryId        String             @db.Uuid
  category          AccountingCategory @relation(fields: [categoryId], references: [id])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model LedgerAccount {
  id             String            @id @default(uuid()) @db.Uuid
  code           String            @unique
  name           String
  type           LedgerAccountType
  active         Boolean           @default(true)
  acceptsEntries Boolean           @default(true)

  parentId       String?           @db.Uuid
  parent         LedgerAccount?    @relation("LedgerAccountHierarchy", fields: [parentId], references: [id])
  children       LedgerAccount[]   @relation("LedgerAccountHierarchy")

  lines          JournalEntryLine[]
  paymentMethodAccounts PaymentMethodAccount[] @relation("PaymentMethodAccountLedger")
  pagoAcreedores  PagoAcreedor[]   @relation("PagoAcreedorTreasuryAccount")
  socioPagos      SocioPago[]      @relation("SocioPagoTreasuryAccount")

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([type])
  @@index([parentId])
}

model JournalEntry {
  id              String             @id @default(uuid()) @db.Uuid
  entryNumber     String             @unique
  sequenceNumber  Int
  fiscalYear      Int
  month           Int
  date            DateTime
  description     String
  notes           String?
  sourceType      String?   // 'VENTA_POS' | 'FIADO_VENTA' | 'PAGO_ACREEDOR' | 'SOCIO_PAGO'
  sourceId        Int?
  status          JournalEntryStatus @default(DRAFT)

  createdById     String             @db.Uuid
  createdBy       User               @relation(fields: [createdById], references: [id])

  postedAt        DateTime?
  voidedAt        DateTime?
  voidReason      String?

  reversalOfId    String?            @unique @db.Uuid
  reversalOf      JournalEntry?      @relation("JournalEntryReversal", fields: [reversalOfId], references: [id])
  reversalEntry   JournalEntry?      @relation("JournalEntryReversal")

  lines           JournalEntryLine[]
  sourceSales             Sale[]           @relation("JournalEntrySale")
  sourceFiadoVentas       FiadoVenta[]     @relation("JournalEntryFiadoVenta")
  sourcePagoAcreedores    PagoAcreedor[]   @relation("JournalEntryPagoAcreedor")
  sourceSocioPagos        SocioPago[]      @relation("JournalEntrySocioPago")

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([fiscalYear, sequenceNumber])
  @@index([date])
  @@index([status])
  @@index([fiscalYear, sequenceNumber])
}

model JournalEntryLine {
  id          String        @id @default(uuid()) @db.Uuid
  entryId     String        @db.Uuid
  entry       JournalEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  accountId   String        @db.Uuid
  account     LedgerAccount @relation(fields: [accountId], references: [id])

  debit       Decimal       @default(0) @db.Decimal(12, 2)
  credit      Decimal       @default(0) @db.Decimal(12, 2)
  description String?

  createdAt   DateTime      @default(now())

  @@index([entryId])
  @@index([accountId])
}

model PaymentMethodAccount {
  id               Int            @id @default(autoincrement())
  paymentMethod    PaymentMethod  @unique
  ledgerAccountId  String         @db.Uuid
  ledgerAccount    LedgerAccount  @relation("PaymentMethodAccountLedger", fields: [ledgerAccountId], references: [id])
}

model Acreedor {
  id          Int           @id @default(autoincrement())
  nombre      String
  telefono    String?
  notas       String?
  activo      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  fiadoVentas FiadoVenta[]
  pagos       PagoAcreedor[]
}

model FiadoVenta {
  id         Int      @id @default(autoincrement())
  ventaId    String   @unique @db.Uuid
  acreedorId Int
  monto      Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  venta      Sale     @relation(fields: [ventaId], references: [id])
  acreedor   Acreedor @relation(fields: [acreedorId], references: [id])
  journalEntryId   String?        @unique @db.Uuid
  journalEntry     JournalEntry?  @relation("JournalEntryFiadoVenta", fields: [journalEntryId], references: [id])

  @@index([acreedorId])
  @@index([ventaId])
}

model PagoAcreedor {
  id         Int      @id @default(autoincrement())
  acreedorId Int
  monto      Decimal  @db.Decimal(10, 2)
  medioPago  String
  fecha      DateTime
  notas      String?
  createdAt  DateTime @default(now())
  acreedor        Acreedor        @relation(fields: [acreedorId], references: [id])
  journalEntryId   String?         @unique @db.Uuid
  journalEntry     JournalEntry?   @relation("JournalEntryPagoAcreedor", fields: [journalEntryId], references: [id])
  treasuryAccountId String?        @db.Uuid
  treasuryAccount  LedgerAccount?  @relation("PagoAcreedorTreasuryAccount", fields: [treasuryAccountId], references: [id])

  @@index([acreedorId])
}

model MpCityMapping {
  zipCode          String   @id @map("zip_code")
  cityName         String   @map("city_name")
  stateName        String   @map("state_name")
  neighborhoodName String   @map("neighborhood_name")
  mlCityId         String   @map("ml_city_id")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("mp_city_mappings")
}

// ─── Internet Vouchers ───────────────────────────────────

model InternetPlan {
  id                String        @id @default(uuid()) @db.Uuid
  name              String
  duration          Int
  idleTimeout       Int           @default(1800)
  downloadBandwidth String        @default("10M")
  uploadBandwidth   String        @default("2M")
  price             Decimal       @db.Decimal(10, 2)
  active            Boolean       @default(true)
  position          Int           @default(0)
  productId         String?       @unique @db.Uuid
  product           Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  categoryId        String?       @db.Uuid
  vouchers          SaleVoucher[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model SaleVoucher {
  id        String       @id @default(uuid()) @db.Uuid
  saleId    String       @db.Uuid
  sale      Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  planId    String       @db.Uuid
  plan      InternetPlan @relation(fields: [planId], references: [id])
  pin        String
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

// ─── Socios ──────────────────────────────────────────────

enum SocioEstado {
  ACTIVO
  INACTIVO
  SUSPENDIDO
}

enum SocioCuotaEstado {
  PENDIENTE
  PARCIAL
  PAGADO
}

model SocioTipo {
  id           Int                 @id @default(autoincrement())
  nombre       String              @unique
  montoMensual Decimal             @db.Decimal(10, 2)
  comentario   String?
  activo       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  historial    SocioTipoHistorial[]
  socios       Socio[]
  beneficios   SocioBeneficio[]
}

model SocioTipoHistorial {
  id             Int       @id @default(autoincrement())
  socioTipoId    Int
  socioTipo      SocioTipo @relation(fields: [socioTipoId], references: [id])
  monto          Decimal   @db.Decimal(10, 2)
  vigenciaDesde  DateTime

  @@index([socioTipoId])
  @@index([vigenciaDesde])
}

model Socio {
  id              Int          @id @default(autoincrement())
  uuid            String       @unique @default(uuid()) @db.Uuid
  nroSocio        Int
  dni             String
  apellido        String
  nombre          String
  fechaNacimiento DateTime?
  telefono        String?
  direccion       String?
  socioTipoId     Int
  socioTipo       SocioTipo    @relation(fields: [socioTipoId], references: [id])
  fechaAlta       DateTime
  estado          SocioEstado  @default(ACTIVO)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  cuotas          SocioCuota[]
  canjes          SocioCanje[]

  @@unique([nroSocio])
  @@index([socioTipoId])
  @@index([estado])
}

model SocioCuota {
  id            Int             @id @default(autoincrement())
  socioId       Int
  socio         Socio           @relation(fields: [socioId], references: [id])
  mes           Int
  anio          Int
  montoOriginal Decimal         @db.Decimal(10, 2)
  montoPagado   Decimal         @default(0) @db.Decimal(10, 2)
  estado        SocioCuotaEstado @default(PENDIENTE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  pagos         SocioPago[]

  @@unique([socioId, mes, anio])
  @@index([socioId])
  @@index([mes, anio])
}

model SocioPago {
  id                Int             @id @default(autoincrement())
  socioCuotaId      Int
  socioCuota        SocioCuota      @relation(fields: [socioCuotaId], references: [id])
  monto             Decimal         @db.Decimal(10, 2)
  fecha             DateTime
  observacion       String?
  journalEntryId    String?         @unique @db.Uuid
  journalEntry      JournalEntry?   @relation("JournalEntrySocioPago", fields: [journalEntryId], references: [id])
  treasuryAccountId String?         @db.Uuid
  treasuryAccount   LedgerAccount?  @relation("SocioPagoTreasuryAccount", fields: [treasuryAccountId], references: [id])
  createdAt         DateTime        @default(now())

  @@index([socioCuotaId])
}

model SocioBeneficio {
  id              String        @id @default(uuid()) @db.Uuid
  socioTipoId     Int
  socioTipo       SocioTipo     @relation(fields: [socioTipoId], references: [id])
  categoriaProdId String?       @db.Uuid
  categoria       Category?     @relation(fields: [categoriaProdId], references: [id])
  productoId      String?       @db.Uuid
  producto        Product?      @relation(fields: [productoId], references: [id])
  porcentaje      Decimal       @db.Decimal(5, 2)
  descuentoMaximo Decimal?      @db.Decimal(10, 2)
  limiteDiario    Int?
  activo          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  canjes          SocioCanje[]

  @@unique([socioTipoId, categoriaProdId])
  @@unique([socioTipoId, productoId])
  @@index([socioTipoId])
  @@index([categoriaProdId])
  @@index([productoId])
}

model SocioCanje {
  id                String         @id @default(uuid()) @db.Uuid
  socioBeneficioId  String         @db.Uuid
  socioBeneficio    SocioBeneficio @relation(fields: [socioBeneficioId], references: [id])
  socioId           Int
  socio             Socio          @relation(fields: [socioId], references: [id])
  ventaId           String?        @db.Uuid
  montoDescontado   Decimal        @db.Decimal(10, 2)
  fecha             DateTime       @default(now())
  usuarioId         String         @db.Uuid
  posId             String?
  createdAt         DateTime       @default(now())

  @@index([socioBeneficioId])
  @@index([socioId])
  @@index([fecha])
}

// ─── Players / Jugadores ────────────────────────────────

enum Sex {
  M
  F
}

enum AllowedSex {
  M
  F
  X
}

enum PlayerCategoryType {
  AGE
  BIRTH_YEAR
}

model Player {
  id            Int               @id @default(autoincrement())
  firstName     String
  lastName      String
  dni           String?
  birthDate     DateTime
  sex           Sex
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  tournaments   TournamentPlayer[]

  @@map("players")
}

model PlayerCategory {
  id              Int                  @id @default(autoincrement())
  name            String
  restrictionType PlayerCategoryType
  ageMin          Int?
  ageMax          Int?
  ageCutoffMonth  Int?                 @default(12)
  ageCutoffDay    Int?                 @default(31)
  birthYear       Int?
  active          Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  tournaments     TournamentCategory[]

  @@map("player_categories")
}

model Tournament {
  id             Int                  @id @default(autoincrement())
  name           String
  year           Int
  allowedSex     AllowedSex
  birthYearMin   Int?
  birthYearMax   Int?
  minPlayers     Int?
  maxPlayers     Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  categories     TournamentCategory[]
  players        TournamentPlayer[]

  @@map("tournaments")
}

model TournamentCategory {
  tournamentId   Int
  playerCategoryId Int
  tournament     Tournament       @relation(fields: [tournamentId], references: [id])
  category       PlayerCategory   @relation(fields: [playerCategoryId], references: [id])

  @@id([tournamentId, playerCategoryId])
  @@map("tournament_categories")
}

model TournamentPlayer {
  id               Int        @id @default(autoincrement())
  playerId         Int
  tournamentId     Int
  playerCategoryId Int
  fichadoAt        DateTime   @default(now())
  player           Player     @relation(fields: [playerId], references: [id])
  tournament       Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([playerId, tournamentId])
  @@map("tournament_players")
}

model UserModulePermission {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    ModuleKey
  access    ModuleAccess

  @@unique([userId, module])
}
