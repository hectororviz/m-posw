# --- Docker ---
# Tag de la imagen a usar. Para rollback, cambiar a v1.1.0 (estable).
DOCKER_TAG=latest

# --- DB ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public

# --- Backend ---
JWT_SECRET=
CORS_ORIGIN=

# Credenciales de administrador inicial
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Front (Vite) ---
# Porque Caddy/Nginx expone la API en /api/*
VITE_API_BASE_URL=/api

# Dejalo vacío si vas a proxyar /uploads con Caddy/Nginx (recomendado)
VITE_UPLOADS_BASE_URL=

# --- MercadoPago ---
# Credenciales de la cuenta de MercadoPago (producción o pruebas)
MP_ACCESS_TOKEN=
MP_COLLECTOR_ID=
MP_CURRENCY_ID=ARS

# Integrator ID opcional, solo para partners certificados
MP_INTEGRATOR_ID=

# IDs externos de Store y POS configurados en MercadoPago
MP_DEFAULT_EXTERNAL_STORE_ID=
MP_DEFAULT_EXTERNAL_POS_ID=

# Secreto para validar firma de webhooks (opcional en desarrollo)
MP_WEBHOOK_SECRET=
MP_WEBHOOK_SECRET_LIVE=
MP_WEBHOOK_SECRET_TEST=

# Setear en 'true' para rechazar webhooks sin firma válida (requiere MP_WEBHOOK_SECRET)
# En producción recomendado: true
# En desarrollo/pruebas: false
MP_WEBHOOK_STRICT_PAYMENT=false

# --- MercadoPago OAuth ---
INSTANCE_SUBDOMAIN=soler
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_OAUTH_REDIRECT_URI=https://oauth.mposw.com.ar/callback

# --- Ligas Deportivas (Supabase) ---
# URL y clave anon de Supabase para datos de ligas
SUPABASE_URL=https://yvwazzwwlpkfhyefnqfo.supabase.co
SUPABASE_ANON_KEY=
